THREADLINE_TOKEN=replace-with-a-long-random-secret
THREADLINE_HTTP_PORT=3000
# Set this to the eventual Web origin when it is served separately.
THREADLINE_CORS_ORIGIN=
# Application safeguards. Production should set TRUST_PROXY=true only behind a trusted proxy.
THREADLINE_BODY_LIMIT_BYTES=262144
THREADLINE_RATE_LIMIT_MAX=120
THREADLINE_RATE_LIMIT_WINDOW_MS=60000
THREADLINE_TRUST_PROXY=false
# Optional outbound Telegram delivery. Set both values to enable notifications.
THREADLINE_TELEGRAM_BOT_TOKEN=
THREADLINE_TELEGRAM_CHAT_ID=
# Optional HTTP proxy, e.g. http://127.0.0.1:7890 for a local Clash instance.
THREADLINE_HTTP_PROXY=
# Delivery attempts include the initial request. Defaults to 3.
THREADLINE_NOTIFICATION_RETRY_ATTEMPTS=3
