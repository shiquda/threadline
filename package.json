{
  "name": "threadline",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted Human-Agent Gateway",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b && npm run build -w @threadline/web",
    "typecheck": "tsc -b --pretty false",
    "test": "npm run build && vitest run",
    "dev:api": "npm run dev -w @threadline/api",
    "dev:cli": "npm run dev -w @threadline/cli --",
    "dev:web": "npm run dev -w @threadline/web"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
