# Copy to .env.production on the VPS. Keep this file private: chmod 600 .env.production.
THREADLINE_TOKEN=replace-with-a-random-48-byte-secret
THREADLINE_CORS_ORIGIN=https://threadline.example.com
THREADLINE_BODY_LIMIT_BYTES=262144
THREADLINE_RATE_LIMIT_MAX=120
THREADLINE_RATE_LIMIT_WINDOW_MS=60000
THREADLINE_TRUST_PROXY=true

# Optional outbound Telegram notification.
THREADLINE_TELEGRAM_BOT_TOKEN=
THREADLINE_TELEGRAM_CHAT_ID=
THREADLINE_HTTP_PROXY=
THREADLINE_NOTIFICATION_RETRY_ATTEMPTS=3

# Create a remotely-managed Cloudflare Tunnel and paste its token here.
CLOUDFLARE_TUNNEL_TOKEN=replace-with-the-cloudflare-tunnel-token
